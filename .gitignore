# Unity .gitignore — cross-platform (Windows/Mac).
# Asset .meta files, ProjectSettings/, and Packages/manifest ARE tracked so a fresh
# clone on any machine reconstructs the project. Library/Temp/Obj are regenerated locally.
# Metas inside ignored folders stay ignored (git does not descend into ignored dirs).

# ----- Unity-generated (regenerated locally, never commit) -----
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# ----- IDE / solution / project files (auto-generated) -----
.vs/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.tmp
*.tmp_proj
ExportedObj/
.consulo/
.gradle/

# ----- OS junk -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
*.stackdump
/nul

# ----- Build / package outputs -----
*.apk
*.aab
*.unitypackage
*.app
crashlytics-build.properties

# ----- Logs / test output / scratch -----
sysinfo.txt
*.log
consolelogs.txt
ConsoleLogs.txt
**/ConsoleLogs.txt
**/consolelogs.txt
*.diff
TestLog-*.txt
TestResults-*.xml
**/TestResults*.xml
**/*TestResult*.xml

# Files renamed with a .TODELETE suffix (pending cleanup — never commit)
*.TODELETE

# ----- Unity caches / generated assets (safe to regenerate) -----
# (folder + its sibling .meta, so the meta of an ignored folder isn't tracked)
/Assets/SceneDependencyCache/
/Assets/SceneDependencyCache.meta
/Assets/SceneTemplateAssets/
/Assets/SceneTemplateAssets.meta
/Assets/Screenshots/
/Assets/Screenshots.meta
/ProfilerCaptures/
/Assets/Temp.meta
/Assets/logs.meta

# TextMesh Pro package resources — re-import via Window > TextMeshPro > Import
# Essentials on a new machine (package GUIDs are stable, so references survive).
/Assets/TextMesh Pro/
/Assets/TextMesh Pro.meta

# Default Unity tutorial sample (unused)
/Assets/TutorialInfo/
/Assets/TutorialInfo.meta

# ----- Third-party imported packs (do NOT vendor; re-import locally) -----
# Bezi Sidekick: third-party Editor-only AI tool, embedded package with closed
# binaries and NOT in manifest.json — re-install locally rather than commit.
/Packages/com.bezi.sidekick/
/Assets/Synty/
/Assets/Synty.meta
/Assets/Kevin Iglesias/
/Assets/Kevin Iglesias.meta
/Assets/ThirdParty/
/Assets/ThirdParty.meta
/Assets/Human*

# ----- Video recordings (Unity Recorder output — not source) -----
*.mp4
*.mov
*.webm

# ----- AI / local tooling folders -----
.claude/
.agents/
.vscode/mcp*
.mcp*
skills-lock.json
ugs_installer
